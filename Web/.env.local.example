# Plantilla de variables de entorno del frontend (Vite). Copiar a .env.local
# y completar. .env.local NUNCA se versiona (ver .gitignore).

# Firebase (claves públicas del proyecto web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Maps (geolocalizador normativo)
VITE_GOOGLE_MAPS_API_KEY=

# App Check — reCAPTCHA v3 (site key pública). Si se deja vacío, App Check no se
# inicializa (útil en dev). En producción es OBLIGATORIO para que las Cloud
# Functions con enforceAppCheck acepten las solicitudes del frontend.
VITE_RECAPTCHA_V3_SITE_KEY=
